# LLM Provider — at least one required
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# GitHub API token — optional but strongly recommended
# Without it: 60 req/hour limit, no GraphQL pinned repos
# With it   : 5000 req/hour, full GraphQL access
GITHUB_TOKEN=your_github_personal_access_token

# Default LLM provider (gemini | openai | groq)
DEFAULT_LLM=groq

# Optional model overrides
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile

# Default output file
DEFAULT_OUTPUT=./README.md